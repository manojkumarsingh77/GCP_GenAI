# ---- Copy to `.env` and fill in your values -------------------------------

# Use Vertex AI (recommended for this project) instead of AI Studio API keys
GOOGLE_GENAI_USE_VERTEXAI=TRUE

# Your GCP trial project
GOOGLE_CLOUD_PROJECT=project-ef200147-6b7b-4fd8-9bb
GOOGLE_CLOUD_LOCATION=us-central1

# Model for all agents (trial-friendly; swap to gemini-2.5-pro to compare)
MODEL=gemini-2.5-flash

# Printed by: python setup/02_create_rag_corpus.py
# Format: projects/<PROJECT_NUMBER>/locations/us-central1/ragCorpora/<ID>
RAG_CORPUS=projects/275211854353/locations/us-central1/ragCorpora/5615830405656608768

# LEAVE EMPTY for local dev (MCP server auto-launches over stdio).
# Set to your Cloud Run URL + /mcp for the production module, e.g.
# MCP_SERVER_URL=https://retail-ops-mcp-xxxx-uc.a.run.app/mcp
MCP_SERVER_URL=https://retail-ops-mcp-kgyb6tpewa-uc.a.run.app

# Staging bucket for Agent Engine deployment (Module 7)
STAGING_BUCKET=gs://project-ef200147-6b7b-4fd8-9bb-agent-staging
